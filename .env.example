# PostgreSQL
DATABASE_URL=postgres://api_anything:api_anything@localhost:5432/api_anything

# Event Bus (默认 pg，可选 kafka)
EVENT_BUS_TYPE=pg          # pg 或 kafka
KAFKA_BROKERS=localhost:9092

# OTel
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Server
API_HOST=0.0.0.0
API_PORT=8080

# 告警通知 (可选)
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
ALERT_WEBHOOK_TYPE=slack   # slack 或 dingtalk

# 插件目录
PLUGIN_DIR=./plugins

# LLM 配置（用于 AI 增强的接口转换，无 Key 时自动降级为确定性规则映射）
# Provider: anthropic | openai | gemini | glm | qwen | kimi | deepseek
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# 智谱 GLM
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 阿里通义千问 Qwen
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 月之暗面 Kimi (Moonshot)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 路由轮询间隔（秒，默认 5）
ROUTE_POLL_INTERVAL_SECS=5

# Logging
RUST_LOG=api_anything=debug,tower_http=debug
