                    "rate": {
                      "type": "string"
                    },
                    "rate_precision": {
                      "type": "integer"
                    },
                    "rate_timestamp": {
                      "type": "string"
                    },
                    "sell_rate": {
                      "type": "string"
                    },
                    "to_currency": {
                      "type": "string"
                    },
                    "valid_until": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "from_currency",
                    "to_currency",
                    "rate",
                    "rate_precision",
                    "buy_rate",
                    "sell_rate",
                    "mid_rate",
                    "rate_timestamp",
                    "valid_until"
