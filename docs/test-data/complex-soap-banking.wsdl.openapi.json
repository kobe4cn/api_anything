                      "required": [
                        "amount",
                        "currency_code",
                        "precision"
                      ],
                      "type": "object"
                    },
                    "status": {
                      "type": "string"
                    },
                    "transaction_id": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "transaction_id",
                    "status",
                    "fee",
                    "executed_at"
                  ],
                  "type": "object"
