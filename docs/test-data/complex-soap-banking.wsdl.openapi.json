                      "type": "object"
                    },
                    "ledger_balance": {
                      "properties": {
                        "amount": {
                          "type": "string"
                        },
                        "currency_code": {
                          "type": "string"
                        },
                        "precision": {
                          "type": "integer"
                        }
                      },
                      "required": [
                        "amount",
                        "currency_code",
                        "precision"
                      ],
                      "type": "object"
                    }
                  },
                  "required": [
                    "account_number",
                    "account_type",
                    "available_balance",
                    "ledger_balance",
                    "frozen_amount",
                    "as_of_datetime"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Retrieves account balance information including available and ledger balances."
