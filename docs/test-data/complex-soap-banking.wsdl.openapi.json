{
  "info": {
    "title": "retest-complex-soap API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/gw/account": {
      "post": {
        "operationId": "createAccount",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "account_type": {
                    "type": "string"
                  },
                  "branch_code": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "initial_deposit": {
                    "properties": {
                      "amount": {
                        "type": "string"
                      },
                      "currency_code": {
                        "type": "string"
                      },
                      "precision": {
                        "type": "integer"
                      }
                    },
                    "required": [
                      "amount",
                      "currency_code",
                      "precision"
                    ],
                    "type": [
                      "object",
                      "null"
                    ]
                  },
                  "owner": {
                    "properties": {
                      "address": {
                        "properties": {
                          "city": {
                            "type": "string"
                          },
                          "country_code": {
                            "type": "string"
                          },
                          "postal_code": {
                            "type": "string"
                          },
                          "state_province": {
                            "type": "string"
                          },
                          "street_line1": {
                            "type": "string"
                          },
                          "street_line2": {
                            "type": [
                              "string",
                              "null"
                            ]
                          }
                        },
                        "required": [
                          "street_line1",
                          "city",
                          "state_province",
                          "postal_code",
                          "country_code"
                        ],
                        "type": "object"
                      },
                      "date_of_birth": {
                        "type": "string"
                      },
                      "email": {
                        "type": "string"
                      },
                      "full_name": {
                        "type": "string"
                      },
                      "national_id": {
                        "type": "string"
                      },
                      "owner_id": {
                        "type": "string"
                      },
                      "phone": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "owner_id",
                      "full_name",
                      "national_id",
                      "date_of_birth",
                      "email",
                      "phone",
                      "address"
                    ],
                    "type": "object"
                  },
                  "preferred_currency": {
                    "type": "string"
                  }
                },
                "required": [
                  "owner",
                  "account_type",
                  "preferred_currency"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "account_number": {
                      "type": "string"
                    },
                    "account_type": {
                      "type": "string"
                    },
                    "created_at": {
                      "type": "string"
                    },
                    "iban": {
                      "type": "string"
                    },
                    "kyc_status": {
                      "type": "string"
                    },
                    "swift_bic": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "account_number",
                    "account_type",
                    "iban",
                    "swift_bic",
                    "created_at",
                    "kyc_status"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Creates a new bank account for a specified owner with optional initial deposit."
      }
    },
    "/gw/account/close": {
      "post": {
        "operationId": "closeAccount",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "account_number": {
                    "type": "string"
                  },
                  "authorized_by": {
                    "type": "string"
                  },
                  "reason": {
                    "type": "string"
                  },
                  "transfer_balance_to": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                },
                "required": [
                  "account_number",
                  "reason",
                  "authorized_by"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "account_number": {
                      "type": "string"
                    },
                    "balance_transfer_id": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "closed_at": {
                      "type": "string"
                    },
                    "confirmation_number": {
                      "type": "string"
                    },
                    "final_balance": {
                      "properties": {
                        "amount": {
                          "type": "string"
                        },
                        "currency_code": {
                          "type": "string"
                        },
                        "precision": {
                          "type": "integer"
                        }
                      },
                      "required": [
                        "amount",
                        "currency_code",
                        "precision"
                      ],
                      "type": "object"
                    }
                  },
                  "required": [
                    "account_number",
                    "closed_at",
                    "final_balance",
                    "confirmation_number"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Closes an existing bank account with optional balance transfer."
      }
    },
    "/gw/balance": {
      "post": {
        "operationId": "getBalance",
