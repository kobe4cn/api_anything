    "/gw/transfer": {
      "post": {
        "operationId": "transferFunds",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "amount": {
                    "properties": {
                      "amount": {
                        "type": "string"
                      },
                      "currency_code": {
                        "type": "string"
                      },
                      "precision": {
                        "type": "integer"
                      }
                    },
                    "required": [
                      "amount",
                      "currency_code",
                      "precision"
