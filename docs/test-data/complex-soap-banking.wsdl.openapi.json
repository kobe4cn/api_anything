                        "properties": {
                          "amount": {
                            "properties": {
                              "amount": {
                                "type": "string"
                              },
                              "currency_code": {
                                "type": "string"
                              },
                              "precision": {
                                "type": "integer"
                              }
                            },
                            "required": [
                              "amount",
                              "currency_code",
                              "precision"
                            ],
                            "type": "object"
                          },
                          "balance_after": {
                            "properties": {
                              "amount": {
                                "type": "string"
                              },
                              "currency_code": {
                                "type": "string"
                              },
                              "precision": {
                                "type": "integer"
                              }
                            },
                            "required": [
                              "amount",
                              "currency_code",
                              "precision"
                            ],
                            "type": "object"
