                      "vaccine": {
                        "type": "string"
                      },
                      "veterinarian": {
                        "type": "string"
                      }
                    },
                    "type": "object"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Get all vaccinations for a pet"
      },
      "post": {
        "operationId": "addVaccination",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "date": {
                    "type": "string"
                  },
                  "vaccine": {
                    "type": "string"
                  },
                  "veterinarian": {
                    "type": "string"
                  }
                },
                "required": [
                  "vaccine",
                  "date"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "date": {
                      "type": "string"
                    },
                    "id": {
                      "type": "integer"
                    },
                    "nextDueDate": {
                      "type": "string"
                    },
                    "vaccine": {
                      "type": "string"
                    },
                    "veterinarian": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Add a vaccination record for a pet"
