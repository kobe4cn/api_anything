      "get": {
        "operationId": "getPetById",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "age": {
                      "type": "integer"
                    },
                    "breed": {
                      "type": "string"
                    },
                    "id": {
                      "type": "integer"
                    },
                    "name": {
                      "type": "string"
                    },
                    "owner": {
                      "$ref": "#/definitions/Owner"
                    },
                    "species": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "tags": {
                      "items": {
                        "type": "string"
                      },
                      "type": "array"
                    },
                    "vaccinations": {
                      "items": {
                        "$ref": "#/definitions/Vaccination"
                      },
                      "type": "array"
                    },
                    "weight": {
                      "type": "number"
                    }
