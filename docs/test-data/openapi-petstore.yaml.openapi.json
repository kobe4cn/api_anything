{
  "info": {
    "title": "test-openapi-petstore API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/gw/pets": {
      "get": {
        "operationId": "listPets",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "properties": {
                      "age": {
                        "type": "integer"
                      },
                      "breed": {
                        "type": "string"
                      },
                      "id": {
                        "type": "integer"
                      },
                      "name": {
                        "type": "string"
                      },
                      "owner": {
                        "$ref": "#/definitions/Owner"
                      },
                      "species": {
                        "type": "string"
                      },
                      "status": {
                        "type": "string"
                      },
                      "tags": {
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "vaccinations": {
                        "items": {
                          "$ref": "#/definitions/Vaccination"
                        },
                        "type": "array"
                      },
                      "weight": {
                        "type": "number"
                      }
                    },
                    "type": "object"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "List all pets in the store"
      },
      "post": {
        "operationId": "createPet",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "age": {
                    "type": "integer"
                  },
                  "breed": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "owner": {
                    "$ref": "#/definitions/Owner"
                  },
                  "species": {
                    "type": "string"
                  },
                  "weight": {
                    "type": "number"
                  }
                },
                "required": [
                  "name",
                  "species"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "age": {
                      "type": "integer"
                    },
                    "breed": {
                      "type": "string"
                    },
                    "id": {
                      "type": "integer"
                    },
                    "name": {
                      "type": "string"
                    },
                    "species": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "weight": {
                      "type": "number"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Create a new pet"
      }
    },
