{
  "info": {
    "title": "test-soap-complex-orders API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/gw/orders": {
      "get": {
        "operationId": "listOrders",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "customer_id": {
                    "type": "string"
                  },
                  "date_from": {
                    "type": "string"
                  },
                  "date_to": {
                    "type": "string"
                  },
                  "pagination": {
                    "$ref": "#/definitions/PaginationRequest"
                  },
                  "status_filter": {
                    "type": "string"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "orders": {
                      "items": {
                        "$ref": "#/definitions/OrderSummary"
                      },
                      "type": "array"
                    },
                    "pagination": {
                      "$ref": "#/definitions/PaginationResponse"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "List orders with optional filtering by customer, status, and date range"
      },
      "post": {
        "operationId": "createOrder",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "billing_address": {
                    "$ref": "#/definitions/Address"
                  },
                  "coupon_code": {
                    "type": "string"
                  },
                  "customer_id": {
                    "type": "string"
                  },
                  "items": {
                    "items": {
                      "$ref": "#/definitions/OrderItem"
                    },
                    "type": "array"
                  },
                  "notes": {
                    "type": "string"
                  },
                  "payment_method": {
                    "type": "string"
                  },
                  "shipping_address": {
                    "$ref": "#/definitions/Address"
                  }
                },
                "required": [
                  "customer_id",
                  "items",
                  "payment_method"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "estimated_delivery": {
                      "type": "string"
                    },
                    "order_id": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "total_amount": {
                      "type": "number"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Create a new order with customer information, items, and payment details"
      }
    },
    "/gw/orders/{order_id}": {
      "delete": {
        "operationId": "cancelOrder",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "order_id": {
                    "type": "string"
                  },
                  "reason": {
                    "type": "string"
                  },
                  "refund_requested": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "order_id",
                  "reason"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "cancelled_at": {
                      "type": "string"
                    },
                    "new_status": {
                      "type": "string"
                    },
                    "order_id": {
                      "type": "string"
                    },
                    "previous_status": {
                      "type": "string"
                    },
                    "refund_status": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Cancel an existing order with optional refund request"
      },
      "get": {
        "operationId": "getOrder",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "order_id": {
                    "description": "Unique identifier for the order",
                    "type": "string"
                  }
                },
                "required": [
                  "order_id"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "billing_address": {
                      "$ref": "#/definitions/Address"
                    },
                    "created_at": {
                      "type": "string"
                    },
                    "currency": {
                      "type": "string"
                    },
                    "customer_email": {
                      "type": "string"
                    },
                    "customer_id": {
                      "type": "string"
                    },
                    "customer_name": {
                      "type": "string"
                    },
                    "items": {
                      "items": {
                        "$ref": "#/definitions/OrderItem"
                      },
                      "type": "array"
                    },
                    "order_id": {
                      "type": "string"
                    },
                    "shipping_address": {
                      "$ref": "#/definitions/Address"
                    },
                    "shipping_fee": {
                      "type": "number"
                    },
                    "status": {
                      "type": "string"
                    },
                    "subtotal": {
                      "type": "number"
                    },
                    "tax": {
                      "type": "number"
                    },
                    "total_amount": {
                      "type": "number"
                    },
                    "updated_at": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Retrieve detailed information about a specific order by its ID"
      }
    },
    "/gw/orders/{order_id}/history": {
      "get": {
        "operationId": "getOrderHistory",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "order_id": {
                    "type": "string"
                  },
                  "pagination": {
                    "$ref": "#/definitions/PaginationRequest"
                  }
                },
                "required": [
                  "order_id"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "entries": {
                      "items": {
                        "$ref": "#/definitions/OrderHistoryEntry"
                      },
                      "type": "array"
                    },
                    "order_id": {
                      "type": "string"
                    },
                    "pagination": {
                      "$ref": "#/definitions/PaginationResponse"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Retrieve the history of actions and changes for a specific order"
      }
    }
  }
}