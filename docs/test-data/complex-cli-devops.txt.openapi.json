{
  "info": {
    "title": "test-complex-cli-devops API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/gw/delete/{app}": {
      "delete": {
        "operationId": "deleteApplication",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Deletes a deployed application"
      }
    },
    "/gw/deploy": {
      "post": {
        "operationId": "deployApplication",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "app": {
                    "type": "string"
                  },
                  "entrypoint": {
                    "type": "string"
                  },
                  "project": {
                    "type": "string"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "deployment": {
                      "type": "string"
                    },
                    "url": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Deploys an application using deployctl"
      }
    },
    "/gw/health_check": {
      "get": {
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "output": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Performs a health check on the deployctl service"
      }
    },
    "/gw/logs/{app}": {
      "get": {
        "operationId": "getApplicationLogs",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "logs": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Retrieves logs for a deployed application"
      }
    },
    "/gw/upgrade": {
      "post": {
        "operationId": "upgradeDeployctl",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Upgrades the deployctl CLI tool"
      }
    },
    "/gw/{command}": {
      "get": {
        "operationId": "executeCommand",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "output": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Executes any deployctl subcommand dynamically"
      }
    }
  }
}