{
  "info": {
    "title": "test-ssh-network-switch API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/gw/environment": {
      "post": {
        "operationId": "getEnvironment",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "host": {
                    "description": "Switch hostname or IP",
                    "type": "string"
                  },
                  "user": {
                    "description": "SSH username",
                    "type": "string"
                  }
                },
                "required": [
                  "host",
                  "user"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "fans": {
                      "items": {
                        "type": "string"
                      },
                      "type": "array"
                    },
                    "power_supplies": {
                      "items": {
                        "type": "string"
                      },
                      "type": "array"
                    },
                    "temperature": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Retrieve environment status including fans, temperature, and power supplies"
      }
    },
