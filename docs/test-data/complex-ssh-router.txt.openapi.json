{
  "info": {
    "title": "retest-complex-ssh API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/gw/api/acl/{name}": {
      "get": {
        "operationId": "getAcl",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "acl_name": {
                      "type": "string"
                    },
                    "rule_count": {
                      "type": "integer"
                    },
                    "rules": {
                      "items": {
                        "properties": {
                          "action": {
                            "type": "string"
                          },
                          "match_count": {
                            "type": "string"
                          },
                          "protocol": {
                            "type": "string"
                          },
                          "rule_text": {
                            "type": "string"
                          },
                          "sequence": {
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "type": "array"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Retrieve access control list configuration by name"
      }
    },
    "/gw/api/arp": {
      "get": {
        "operationId": "getArpTable",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "arp_entries": {
                      "items": {
                        "properties": {
                          "address": {
                            "type": "string"
                          },
                          "age": {
                            "type": "string"
                          },
                          "hardware_addr": {
                            "type": "string"
                          },
                          "interface": {
                            "type": "string"
                          },
                          "protocol": {
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "count": {
                      "type": "integer"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Retrieve the ARP table from the remote device"
      }
    },
    "/gw/api/bgp/neighbors/{ip}": {
      "get": {
        "operationId": "getBgpNeighbors",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "output": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Retrieve detailed BGP neighbor information for a specific IP"
      }
    },
    "/gw/api/bgp/summary": {
      "get": {
        "operationId": "getBgpSummary",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "local_as": {
                      "type": "string"
                    },
                    "neighbor_count": {
                      "type": "integer"
                    },
                    "neighbors": {
                      "items": {
                        "properties": {
                          "as": {
                            "type": "string"
                          },
                          "msg_received": {
                            "type": "string"
                          },
                          "msg_sent": {
                            "type": "string"
                          },
                          "neighbor": {
                            "type": "string"
                          },
                          "prefixes": {
                            "type": "string"
                          },
                          "up_down": {
                            "type": "string"
                          },
                          "version": {
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "router_id": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Retrieve BGP summary information including router ID and neighbors"
      }
    },
    "/gw/api/interface/{name}/description": {
      "post": {
        "operationId": "setInterfaceDescription",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "description": {
                    "type": "string"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "output": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Set the description for a specific network interface"
      }
    },
    "/gw/api/interface/{name}/detail": {
      "get": {
        "operationId": "getInterfaceDetail",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "input_rate": {
                      "type": "string"
                    },
                    "last_flapped": {
                      "type": "string"
                    },
                    "link_level": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "output_rate": {
                      "type": "string"
                    },
                    "speed": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Retrieve detailed information about a specific network interface"
      }
    },
    "/gw/api/ospf/database": {
      "get": {
        "operationId": "getOspfDatabase",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "output": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Retrieve OSPF database summary from the remote device"
      }
    },
    "/gw/api/ospf/neighbors": {
      "get": {
        "operationId": "getOspfNeighbors",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "count": {
                      "type": "integer"
                    },
                    "ospf_neighbors": {
                      "items": {
                        "properties": {
                          "address": {
                            "type": "string"
                          },
                          "dead_time": {
                            "type": "string"
                          },
                          "interface": {
                            "type": "string"
                          },
                          "neighbor_id": {
                            "type": "string"
                          },
                          "priority": {
                            "type": "string"
                          },
                          "state": {
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "type": "array"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Retrieve OSPF neighbor information from the remote device"
      }
    },
    "/gw/api/ping": {
      "post": {
        "operationId": "pingDestination",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "count": {
                    "type": "integer"
                  },
                  "destination": {
                    "type": "string"
                  },
                  "size": {
                    "type": "integer"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "packet_loss_percent": {
                      "type": "number"
                    },
                    "packets_received": {
                      "type": "integer"
                    },
                    "packets_transmitted": {
                      "type": "integer"
                    },
                    "rtt_avg_ms": {
                      "type": "number"
                    },
                    "rtt_max_ms": {
                      "type": "number"
                    },
                    "rtt_min_ms": {
                      "type": "number"
                    },
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Execute ping command to test connectivity to a destination"
      }
    },
    "/gw/api/route": {
      "get": {
        "operationId": "getRouteTable",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "count": {
                      "type": "integer"
                    },
                    "routes": {
                      "items": {
                        "properties": {
                          "interface": {
                            "type": "string"
                          },
                          "metric": {
                            "type": "string"
                          },
                          "prefix": {
                            "type": "string"
                          },
                          "protocol": {
                            "type": "string"
                          },
                          "via": {
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "type": "array"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Retrieve the IP routing table from the remote device"
      }
    },
    "/gw/api/route/{protocol}/{prefix}": {
      "get": {
        "operationId": "getSpecificRoute",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "count": {
                      "type": "integer"
                    },
                    "routes": {
                      "items": {
                        "properties": {
                          "interface": {
                            "type": "string"
                          },
                          "metric": {
                            "type": "string"
                          },
                          "prefix": {
                            "type": "string"
                          },
                          "protocol": {
                            "type": "string"
                          },
                          "via": {
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "type": "array"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Retrieve a specific route from the routing table by protocol and prefix"
      }
    },
    "/gw/api/traceroute/{destination}": {
      "post": {
        "operationId": "tracerouteDestination",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "hop_count": {
                      "type": "integer"
                    },
                    "hops": {
                      "items": {
                        "properties": {
                          "address": {
                            "type": "string"
                          },
                          "hop_number": {
                            "type": "string"
                          },
                          "rtt1_ms": {
                            "type": "string"
                          },
                          "rtt2_ms": {
                            "type": "string"
                          },
                          "rtt3_ms": {
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "type": "array"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "429": {
            "description": "Rate limited"
          },
          "502": {
            "description": "Backend error"
          },
          "503": {
            "description": "Circuit breaker open"
          },
          "504": {
            "description": "Backend timeout"
          }
        },
        "summary": "Execute traceroute to trace the path to a destination"
      }
    }
  }
}